# === Contoh konfigurasi — salin ke .env lalu sesuaikan ===
# (.env asli di-gitignore, file ini boleh di-commit)

# --- Iggy (broker) ---
# Saat producer jalan dari HOST (venv) pakai localhost; di dalam compose pakai "iggy".
IGGY_HOST=localhost
IGGY_HTTP_PORT=3000      # HTTP REST API (dipakai producer Minggu 3)
IGGY_TCP_PORT=8090       # binary protocol (dipakai nanti)
IGGY_STREAM=transactions
IGGY_TOPIC=creditcard
IGGY_PARTITIONS=1        # jumlah partisi topik

# Kredensial root Iggy (default bawaan: iggy/iggy).
IGGY_ROOT_USERNAME=iggy
IGGY_ROOT_PASSWORD=iggy

# --- Producer (replay CSV) ---
PRODUCER_RPS=50          # transaksi per detik (simulasi real-time)
# Saat jalan dari host pakai path lokal; di container pakai /data/creditcard.csv.
DATA_PATH=data/creditcard.csv

# --- Bridge (Iggy HTTP -> TCP socket untuk Flink) ---
BRIDGE_BIND_HOST=0.0.0.0     # bind socket (0.0.0.0 agar terjangkau dari container Flink)
BRIDGE_SOCKET_PORT=9999      # port TCP tempat Flink konek (socket_text_stream)
BRIDGE_CONSUMER_ID=10        # id consumer Iggy untuk bridge (terpisah dari consumer_test)
BRIDGE_POLL_COUNT=100        # maks transaksi per poll
BRIDGE_POLL_INTERVAL=0.2     # jeda (dtk) saat poll kosong

# --- Postgres (sink untuk dashboard) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=anomaly
POSTGRES_USER=anomaly
POSTGRES_PASSWORD=ubah_password_ini

# --- ML scorer ---
ECOD_MODEL_PATH=/app/models/ecod.pkl
ANOMALY_THRESHOLD=0.5    # ambang skor → tandai anomali

# --- Dashboard online (Supabase/Postgres) ---
# Dipakai saat deploy Streamlit Cloud (Minggu 6)
DASHBOARD_DB_URL=
